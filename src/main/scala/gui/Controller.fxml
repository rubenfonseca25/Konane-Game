<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" style="-fx-background-color: #D3D3D3;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.Controller">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <GridPane hgap="10" prefWidth="600">

        <columnConstraints>
            <!-- Coluna da esquerda -->
            <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>

            <!-- Coluna da direita -->
            <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
        </columnConstraints>

        <rowConstraints>
            <RowConstraints vgrow="NEVER"/>
        </rowConstraints>

        <!-- Label esquerda -->
        <Label fx:id="lblJogador"
               text="Pretas a Jogar"
               GridPane.columnIndex="0"
               style="-fx-font-size: 18px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #ffffff;
                  -fx-background-color: #2c3e50;
                  -fx-padding: 5 15 5 15;
                  -fx-background-radius: 5;" />

        <!-- Label direita -->
        <Label fx:id="lblCronometro"
               text="Tempo Restante: --s"
               GridPane.columnIndex="1"
               alignment="CENTER_RIGHT"
               maxWidth="Infinity"
               GridPane.halignment="RIGHT"
               style="-fx-font-size: 18px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #e74c3c;
                  -fx-background-color: #636669;
                  -fx-padding: 5 15 5 15;
                  -fx-background-radius: 5;" />

    </GridPane>

    <GridPane fx:id="tabuleiro" alignment="CENTER" hgap="5" vgap="5" />

    <HBox alignment="CENTER" spacing="15">

        <Button fx:id="btnParar" onAction="#handleParar" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15;" text="Parar Capturas" />

        <Button fx:id="btnUndo" onAction="#handleUndo" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15;" text="Desfazer Jogada (Undo)" />

        <Button fx:id="btnReiniciar" onAction="#handleReiniciar" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15;" text="Reiniciar Jogo" />

    </HBox>


</VBox>
